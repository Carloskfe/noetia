COMPOSE_PROJECT_NAME=noetia
# ─── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=noetia
DB_USER=noetia
DB_PASS=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://cache:6379

# ─── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ENDPOINT=storage
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_BOOKS=books
MINIO_BUCKET_AUDIO=audio
MINIO_BUCKET_IMAGES=images
# Public URL used to rewrite presigned URLs so browsers can reach MinIO.
# Dev: http://localhost:9000  |  Prod: your CDN or S3 public endpoint
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_use_a_long_random_string
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Same client ID used to verify mobile ID tokens (can equal GOOGLE_CLIENT_ID)
GOOGLE_MOBILE_CLIENT_ID=

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_changeme
STRIPE_PRICE_INDIVIDUAL_ANNUAL=price_changeme
STRIPE_PRICE_DUAL_MONTHLY=price_changeme
STRIPE_PRICE_DUAL_ANNUAL=price_changeme

# ─── Meilisearch ──────────────────────────────────────────────────────────────
MEILI_HOST=http://search:7700
MEILI_MASTER_KEY=changeme

# ─── Image Generation Service ─────────────────────────────────────────────────
IMAGE_GEN_URL=http://image-gen:5000

# ─── Social Publishing (OAuth + direct post) ──────────────────────────────────
API_URL=http://localhost:4000
SOCIAL_TOKEN_SECRET=changeme_use_a_long_random_string

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_PUBLISH_ENABLED=false

PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# NEXT_PUBLIC prefix exposes the flag to browser bundles
NEXT_PUBLIC_INSTAGRAM_PUBLISH_ENABLED=false

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
# Browser uses /api proxy (same origin); Next.js server forwards to api container
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://api:4000
# Direct URL used only for OAuth redirect links (browser navigation, not fetch)
# Dev: http://localhost:4000  |  Prod: https://noetia.app/api
NEXT_PUBLIC_OAUTH_URL=http://localhost:4000

# ─── Mobile (Expo) ────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Required in production (docker-compose.prod.yml). Change from default.
GRAFANA_ADMIN_PASSWORD=changeme

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# Leave empty to disable Sentry in development. Set in production.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Development: uses Mailhog (add to docker-compose if needed) — no auth required
# Production: set to your SMTP provider (SendGrid, SES, Mailgun, etc.)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Noetia <noreply@noetia.app>
